    "embed:backfill:fast": "VOYAGE_SPEED_MODE=fast node --env-file=.env.local src/lib/migrations/backfill-voyage.mjs",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@pinecone-database/pinecone": "^7.2.0",
    "@supabase/supabase-js": "^2.103.0",
    "@types/web-push": "^3.6.4",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
