# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# DICOM raw data is committed to git so it deploys to Vercel
# Total ~101MB, largest file ~9.5MB - within GitHub and Vercel limits

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local settings (personal, not committed)
.claude/settings.local.json

# Nested git worktrees (Claude session worktrees should never be committed)
.claude/worktrees/

# Third-party marketing screenshots used only for local competitive
# research. Analysis markdown is committed; images are not ours to
# republish.
docs/research/**/screenshots/

# Reference frames and recordings are third-party app screenshots
# staged via symlinks to a sibling worktree. We commit the derived
# analysis markdown (colors.md, typography.md, components.md, flows.md)
# but not the source assets.
docs/reference/*/frames
docs/reference/*/recordings

# ad-hoc local scripts
tmp_*.mjs
tmp_*.ts
tmp_*.js
.playwright-mcp/

# Playwright E2E test outputs
/test-results/
/playwright-report/
/playwright/.cache/
ours-*.png
/tmp/mfn-ref
.firecrawl/
